# SmartPOS API (obrigatório)
SMARTPOS_API_KEY_ID=sua-api-key-id
SMARTPOS_API_KEY_SECRET=sua-api-key-secret

# MySQL Database (obrigatório)
MYSQL_HOST=sua-host-mysql
MYSQL_PORT=3306
MYSQL_DATABASE=seu-banco-de-dados
MYSQL_USER=seu-usuario
MYSQL_PASSWORD=sua-senha

# Autenticação (obrigatório)
AUTH_PASSWORD=sua-senha-de-login
SESSION_SECRET=chave-secreta-aleatoria-min-32-caracteres
